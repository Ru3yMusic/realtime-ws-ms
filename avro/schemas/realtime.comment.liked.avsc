{
  "type": "record",
  "name": "CommentLikedEvent",
  "namespace": "com.rubymusic.realtime",
  "doc": "Emitted by realtime-ws-ms when a user likes or unlikes a comment",
  "fields": [
    { "name": "comment_id",        "type": "string" },
    { "name": "comment_author_id", "type": "string" },
    { "name": "liker_id",          "type": "string" },
    { "name": "liker_username",    "type": "string" },
    { "name": "liker_photo_url",   "type": ["null", "string"], "default": null },
    { "name": "song_id",           "type": "string" },
    { "name": "station_id",        "type": "string" },
    { "name": "timestamp",         "type": "long", "logicalType": "timestamp-millis" },
    { "name": "action",            "type": "string", "default": "like",
      "doc": "Discriminator: 'like' or 'unlike'. Replaces the UNLIKE: username prefix hack." }
  ]
}
