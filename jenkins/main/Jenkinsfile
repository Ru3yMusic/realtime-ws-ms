pipeline {
  agent any
  options {
    skipDefaultCheckout(true)
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '10'))
  }
  environment {
    SONARQUBE_SERVER = 'sonarqube'
    DOCKER_IMAGE = 'darfelio/rbm-realtime-ws'
    DOCKER_TAG = "v${BUILD_NUMBER}"
    DEPLOY_HOST = '146.181.41.236'
    DEPLOY_USER = 'ubuntu'
    PUPPETEER_SKIP_DOWNLOAD = 'true'
    PUPPETEER_SKIP_CHROMIUM_DOWNLOAD = 'true'
  }
  stages {
    stage('Checkout SCM') {
      steps { checkout scm }
    }
    stage('🧪 Tests & Coverage') {
      steps {
        sh 'npm ci'
        sh 'npm run test:cov'
      }
    }
    stage('🔍 SonarQube Analysis') {
      steps {
        script {
          withSonarQubeEnv("${SONARQUBE_SERVER}") {
            sh '''
              sonar-scanner \
                -Dsonar.projectKey=rbm-realtime-ws \
                -Dsonar.sources=src \
                -Dsonar.tests=src \
                -Dsonar.test.inclusions=**/*.spec.ts \
                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
            '''
          }
          timeout(time: 10, unit: 'MINUTES') {
            waitForQualityGate abortPipeline: true
          }
        }
      }
    }
    stage('🔨 Build Image') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'DOCKERHUB_USER', passwordVariable: 'DOCKERHUB_PASS')]) {
          sh '''
            echo "$DOCKERHUB_PASS" | docker login -u "$DOCKERHUB_USER" --password-stdin
            docker buildx build --push -t ${DOCKER_IMAGE}:${DOCKER_TAG} -t ${DOCKER_IMAGE}:latest .
            docker logout
          '''
        }
      }
    }
    stage('🚀 Deploy Application') {
      steps {
        sshagent(credentials: ['arm-ssh-key']) {
          sh """
            ssh -o StrictHostKeyChecking=no ${DEPLOY_USER}@${DEPLOY_HOST} '
              docker pull ${DOCKER_IMAGE}:${DOCKER_TAG} &&
              if grep -q "^REALTIME_WS_TAG=" .env.prod; then
                sed -i "s|^REALTIME_WS_TAG=.*|REALTIME_WS_TAG=${DOCKER_TAG}|" .env.prod;
              else
                echo "REALTIME_WS_TAG=${DOCKER_TAG}" >> .env.prod;
              fi &&
              docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --no-deps realtime-ws-ms
            '
          """
        }
      }
    }
  }
}
